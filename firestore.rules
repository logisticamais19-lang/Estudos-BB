rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;
      allow read, write: if request.auth.uid == '1LOQzxkQGaeQ6ptW3DSGRjkrHRj1';
    }
    
    match /presence/{uid} {
      allow read: if true;
      allow write: if request.auth.uid == uid;
    }
    
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth.uid == '1LOQzxkQGaeQ6ptW3DSGRjkrHRj1';
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
