rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuarios: so o proprio usuario acessa seus dados
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.size() < 50;
    }

    // Cadernos e blocos: tamanho maximo 100KB por documento
    match /users/{uid}/{collection}/{docId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.data.size() < 100;
    }

    // Config publica: somente leitura autenticada (era: if true)
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Presenca online
    match /presence/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Bloquear tudo mais
    match /{document=**} {
      allow read, write: if false;
    }
  }
}