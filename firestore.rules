rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dados do usuario (notas, configs pessoais)
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Sub-documentos diretos do usuario (cadernos, progresso, etc)
    match /users/{uid}/{collection}/{docId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Sub-documentos de segundo nivel (ex: users/{uid}/data/notes)
    match /users/{uid}/{col1}/{doc1}/{col2}/{doc2} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Config publica: somente leitura autenticada
    match /config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Presenca online
    match /presence/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Bloquear tudo mais
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
